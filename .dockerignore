# Ignore unnecessary files in Docker build context
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
*.log

# Ignore output directories (will be created in container)
output/
agent_scratchpad/
samples_artifacts/

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment files (should be mounted or set via env vars)
.env
.env.local

# Documentation that's not needed in container
*.md
!README.md

# Helper scripts (not needed in container)
docker-setup-ssh.sh
docker-check-ssh.sh
# Codex SDK runner is needed, so don't ignore it
# codex-sdk-runner.js

